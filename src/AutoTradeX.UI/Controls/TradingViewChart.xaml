<UserControl x:Class="AutoTradeX.UI.Controls.TradingViewChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent"
             MinHeight="200">

    <Grid>
        <!-- Main Chart Area -->
        <lvc:CartesianChart x:Name="MainChart"
                           Background="Transparent"
                           TooltipPosition="Left"
                           AnimationsSpeed="00:00:00.150"
                           EasingFunction="{x:Null}"
                           MinHeight="200"/>

        <!-- Price Label (Current Price) -->
        <Border x:Name="CurrentPriceLabel"
                Background="#CC7C3AED"
                CornerRadius="4"
                Padding="8,4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,50,10,0"
                Visibility="Collapsed">
            <TextBlock x:Name="CurrentPriceText"
                      Text="$0.00"
                      FontSize="12"
                      FontWeight="Bold"
                      Foreground="White"/>
        </Border>

        <!-- Legend -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="10,10,0,0">
            <!-- Buy Marker Legend -->
            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                <Ellipse Width="10" Height="10" Fill="#10B981"/>
                <TextBlock Text=" Buy" Foreground="#80FFFFFF" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Sell Marker Legend -->
            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                <Ellipse Width="10" Height="10" Fill="#EF4444"/>
                <TextBlock Text=" Sell" Foreground="#80FFFFFF" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Pending Order Legend -->
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Fill="#F59E0B"/>
                <TextBlock Text=" Pending" Foreground="#80FFFFFF" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
