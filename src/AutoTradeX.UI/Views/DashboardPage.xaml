<UserControl x:Class="AutoTradeX.UI.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AutoTradeX.UI.Controls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>
        <!-- Glass Card Style -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#20FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat Card Style -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#18FFFFFF" Offset="0"/>
                        <GradientStop Color="#0AFFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- Mode Tab Button Style -->
        <Style x:Key="ModeTabButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="#15FFFFFF" CornerRadius="10" Padding="16,10" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="text" Text="{TemplateBinding Content}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#5B21B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="text" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#25FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bg" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8B5CF6" Offset="0"/>
                                            <GradientStop Color="#6D28D9" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Button Style for charts -->
        <Style x:Key="TabButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="#10FFFFFF" CornerRadius="6" Padding="8,4" Margin="2,0" Cursor="Hand">
                            <TextBlock x:Name="text" Text="{TemplateBinding Content}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#207C3AED"/>
                                <Setter TargetName="text" Property="Foreground" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#207C3AED" CornerRadius="8" Padding="12,6" Cursor="Hand">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#7C3AED" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#307C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium ScrollBar Thumb -->
        <Style x:Key="PremiumScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumb" CornerRadius="5" Margin="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="0.5"/>
                                    <GradientStop Color="#6D28D9" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#7C3AED" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumb" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#A78BFA" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="0.5"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumb" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#C4B5FD" Offset="0"/>
                                            <GradientStop Color="#A78BFA" Offset="0.5"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="thumb" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#7C3AED" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium ScrollBar -->
        <Style x:Key="PremiumScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#08FFFFFF" CornerRadius="5"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource PremiumScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium ScrollViewer -->
        <Style x:Key="PremiumScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                       Style="{StaticResource PremiumScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource PremiumScrollViewer}">
            <Grid Margin="30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Row 0: Hero Section with Mode Tabs -->
                    <RowDefinition Height="Auto"/>  <!-- Row 1: Dynamic Trading Mode Section -->
                    <RowDefinition Height="Auto"/>  <!-- Row 2: Exchange Wallets -->
                    <RowDefinition Height="Auto"/>  <!-- Row 3: Key Performance Metrics -->
                    <RowDefinition Height="Auto"/>  <!-- Row 4: Performance Chart & Live Monitor -->
                    <RowDefinition Height="Auto"/>  <!-- Row 5: Market Overview & Active Pairs -->
                    <RowDefinition Height="*"/>     <!-- Row 6: Recent Trades & Activity Log -->
                </Grid.RowDefinitions>

                <!-- ========== ROW 0: HERO SECTION WITH MODE TABS ========== -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Balance Overview -->
                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL BALANCE" FontSize="10" Foreground="#60FFFFFF" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalPortfolioValue" Text="$0.00" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <Border x:Name="PnLBadge" Background="#2010B981" CornerRadius="8" Padding="8,4" Margin="0,10,0,0" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TotalPnLPercent" Text="+0.00%" FontSize="12" FontWeight="SemiBold" Foreground="#10B981"/>
                                    <TextBlock x:Name="TotalPnLValue" Text=" (+$0.00)" FontSize="10" Foreground="#10B981" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Today:" FontSize="10" Foreground="#60FFFFFF"/>
                                <TextBlock x:Name="TodayPnL" Text="+$0.00" FontSize="11" FontWeight="SemiBold" Foreground="#10B981" Margin="5,0,10,0"/>
                                <TextBlock Text="Trades:" FontSize="10" Foreground="#60FFFFFF"/>
                                <TextBlock x:Name="TodayTrades" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="White" Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Trading Mode Switcher (CENTER - IMPORTANT) -->
                    <Border Grid.Column="1" Style="{StaticResource GlassCard}" Margin="10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="TRADING MODE" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Mode Tabs -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                <RadioButton x:Name="ModeArbitrage" Content="ARBITRAGE" Tag="🔄"
                                             Style="{StaticResource ModeTabButton}" GroupName="TradingMode"
                                             IsChecked="True" Checked="TradingMode_Changed" Margin="0,0,8,0"/>
                                <RadioButton x:Name="ModeSingleExchange" Content="SINGLE EXCHANGE" Tag="📈"
                                             Style="{StaticResource ModeTabButton}" GroupName="TradingMode"
                                             Checked="TradingMode_Changed" Margin="0,0,8,0"/>
                                <RadioButton x:Name="ModeAITrading" Content="AI TRADING" Tag="🤖"
                                             Style="{StaticResource ModeTabButton}" GroupName="TradingMode"
                                             Checked="TradingMode_Changed"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- System Health Panel -->
                    <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SYSTEM HEALTH" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                    <Border x:Name="SystemHealthBadge" Background="#2010B981" CornerRadius="8" Padding="8,2" Margin="10,0,0,0">
                                        <TextBlock x:Name="SystemHealthText" Text="CHECKING..." FontSize="9" FontWeight="Bold" Foreground="#10B981"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- No Exchange Connected Panel -->
                            <Border x:Name="NoExchangeConnectedPanel" Grid.Row="1" Background="#15EF4444" CornerRadius="10" Padding="12" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="⚠️ No Exchanges Connected" FontSize="12" FontWeight="SemiBold" Foreground="#EF4444"/>
                                    <TextBlock Text="Configure API keys in Settings" FontSize="10" Foreground="#80FFFFFF" Margin="0,5,0,10"/>
                                    <Button Content="→ Go to Settings" Click="GoToSettings_Click" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#20EF4444" CornerRadius="6" Padding="12,6">
                                                    <TextBlock Text="{TemplateBinding Content}" FontSize="10" FontWeight="SemiBold" Foreground="#EF4444" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Exchange Status List -->
                            <ItemsControl x:Name="ExchangeStatusList" Grid.Row="1">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#10FFFFFF" CornerRadius="8" Padding="8,6" Margin="2">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <controls:ExchangeIcon ExchangeName="{Binding Name}" Size="18" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Latency}" FontSize="8" Foreground="#60FFFFFF" Margin="0,0,5,0"/>
                                                    <Ellipse Width="6" Height="6" Fill="{Binding StatusColor}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ========== ROW 1: DYNAMIC TRADING MODE SECTION ========== -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="280" MaxWidth="350"/>
                    </Grid.ColumnDefinitions>

                    <!-- ARBITRAGE MODE PANEL (Default Visible) -->
                    <Border x:Name="ArbitrageModePanel" Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔄 ARBITRAGE MODE" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    <Border x:Name="ArbModeBadge" Background="#2010B981" CornerRadius="6" Padding="8,3" Margin="12,0,0,0">
                                        <TextBlock x:Name="ArbModeText" Text="DUAL BALANCE" FontSize="9" FontWeight="Bold" Foreground="#10B981"/>
                                    </Border>
                                </StackPanel>
                                <Button Content="⚙ Change Mode" HorizontalAlignment="Right" Click="GoToTradingPage_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#15FFFFFF" CornerRadius="6" Padding="10,5">
                                                <TextBlock Text="{TemplateBinding Content}" FontSize="10" Foreground="#80FFFFFF"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Arbitrage Mode Content -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Buy Exchange -->
                                <Border Background="#15FFFFFF" CornerRadius="12" Padding="15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <controls:ExchangeIcon x:Name="BuyExchangeIcon" ExchangeName="Binance" Size="28" Margin="0,0,8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock x:Name="BuyExchangeName" Text="BINANCE" FontSize="11" FontWeight="Bold" Foreground="#F3BA2F"/>
                                                <TextBlock Text="BUY" FontSize="9" Foreground="#60FFFFFF"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock x:Name="BuyPrice" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Spread -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                    <Border x:Name="SpreadBorder" CornerRadius="12" Padding="20,15">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C3AED" Offset="0"/>
                                                <GradientStop Color="#5B21B6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock Text="SPREAD" FontSize="9" Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="SpreadValue" Text="0.00%" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="SpreadAmount" Text="$0.00" FontSize="11" Foreground="#DDFFFFFF" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="→" FontSize="24" Foreground="#40FFFFFF" HorizontalAlignment="Center" Margin="0,5"/>
                                </StackPanel>

                                <!-- Sell Exchange -->
                                <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="12" Padding="15">
                                    <StackPanel HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock x:Name="SellExchangeName" Text="KUCOIN" FontSize="11" FontWeight="Bold" Foreground="#23AF91" HorizontalAlignment="Right"/>
                                                <TextBlock Text="SELL" FontSize="9" Foreground="#60FFFFFF" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                            <controls:ExchangeIcon x:Name="SellExchangeIcon" ExchangeName="KuCoin" Size="28" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="SellPrice" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- SINGLE EXCHANGE MODE PANEL (Hidden by default) -->
                    <Border x:Name="SingleExchangeModePanel" Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,10,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📈 SINGLE EXCHANGE MODE" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    <Border Background="#2000D4FF" CornerRadius="6" Padding="8,3" Margin="12,0,0,0">
                                        <TextBlock Text="SPOT TRADING" FontSize="9" FontWeight="Bold" Foreground="#00D4FF"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Single Exchange Content -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Exchange Selector -->
                                <Border Background="#15FFFFFF" CornerRadius="12" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="SELECT EXCHANGE" FontSize="9" Foreground="#60FFFFFF" Margin="0,0,0,10"/>
                                        <ComboBox x:Name="SingleExchangeSelector" Width="140" SelectedIndex="0" SelectionChanged="SingleExchangeSelector_Changed">
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="Background" Value="#20FFFFFF"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Style>
                                            </ComboBox.Style>
                                            <ComboBoxItem Content="Binance"/>
                                            <ComboBoxItem Content="KuCoin"/>
                                            <ComboBoxItem Content="OKX"/>
                                            <ComboBoxItem Content="Bybit"/>
                                            <ComboBoxItem Content="Gate.io"/>
                                            <ComboBoxItem Content="Bitkub"/>
                                        </ComboBox>
                                        <TextBlock x:Name="SingleExchangeBalance" Text="Balance: $0.00" FontSize="11" Foreground="#80FFFFFF" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Current Price Display -->
                                <Border Grid.Column="1" Background="#15FFFFFF" CornerRadius="12" Padding="20" Margin="15,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <controls:CoinIcon x:Name="SinglePairIcon" Symbol="BTC" Size="32" Margin="0,0,10,0"/>
                                            <TextBlock x:Name="SinglePairSymbol" Text="BTC/USDT" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="SinglePairPrice" Text="$0.00" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                            <TextBlock x:Name="SinglePairChange" Text="+0.00%" FontSize="14" FontWeight="SemiBold" Foreground="#10B981"/>
                                            <TextBlock Text=" (24h)" FontSize="10" Foreground="#60FFFFFF" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Quick Stats -->
                                <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="12" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="24H STATS" FontSize="9" Foreground="#60FFFFFF" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="High" FontSize="9" Foreground="#60FFFFFF"/>
                                                <TextBlock x:Name="SingleHigh24h" Text="$0.00" FontSize="12" FontWeight="SemiBold" Foreground="#10B981"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                                <TextBlock Text="Low" FontSize="9" Foreground="#60FFFFFF"/>
                                                <TextBlock x:Name="SingleLow24h" Text="$0.00" FontSize="12" FontWeight="SemiBold" Foreground="#EF4444"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2">
                                                <TextBlock Text="Volume" FontSize="9" Foreground="#60FFFFFF"/>
                                                <TextBlock x:Name="SingleVolume24h" Text="$0" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- AI TRADING MODE PANEL (Hidden by default) -->
                    <Border x:Name="AITradingModePanel" Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,10,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🤖 AI TRADING MODE" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    <Border Background="#20F59E0B" CornerRadius="6" Padding="8,3" Margin="12,0,0,0">
                                        <TextBlock x:Name="AIStrategyText" Text="MOMENTUM" FontSize="9" FontWeight="Bold" Foreground="#F59E0B"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- AI Trading Content -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- AI Signal Panel -->
                                <Border Background="#15FFFFFF" CornerRadius="12" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="AI SIGNAL" FontSize="9" Foreground="#60FFFFFF" Margin="0,0,0,10"/>
                                        <Border x:Name="AISignalBorder" CornerRadius="10" Padding="15,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#2010B981" Offset="0"/>
                                                    <GradientStop Color="#1010B981" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock x:Name="AISignalText" Text="BUY" FontSize="24" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                                <TextBlock x:Name="AIConfidence" Text="Confidence: 85%" FontSize="10" Foreground="#80FFFFFF" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- AI Stats -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                    <Border Background="#15FFFFFF" CornerRadius="10" Padding="20,15">
                                        <StackPanel>
                                            <TextBlock Text="AI ACCURACY" FontSize="9" Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="AIAccuracy" Text="78%" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Last 30 days" FontSize="9" Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- AI Position -->
                                <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="12" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="CURRENT POSITION" FontSize="9" Foreground="#60FFFFFF" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <controls:CoinIcon x:Name="AIPositionIcon" Symbol="BTC" Size="24" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="AIPositionSymbol" Text="BTC/USDT" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="AIPositionPnL" Text="+$0.00" FontSize="18" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                        <TextBlock x:Name="AIPositionStatus" Text="No Active Position" FontSize="10" Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Bot Control Panel (Shared across all modes) -->
                    <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="BOT CONTROL" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,15"/>

                            <!-- Bot Status -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <!-- Status Indicator -->
                                <Grid HorizontalAlignment="Center" Margin="0,0,0,15">
                                    <Ellipse x:Name="BotStatusOuter" Width="60" Height="60" Opacity="0.3">
                                        <Ellipse.Fill>
                                            <SolidColorBrush x:Name="BotStatusOuterBrush" Color="#808080"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Ellipse x:Name="BotStatusInner" Width="40" Height="40">
                                        <Ellipse.Fill>
                                            <SolidColorBrush x:Name="BotStatusInnerBrush" Color="#808080"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!-- Rotating Logo -->
                                    <Border Width="30" Height="30">
                                        <Border.RenderTransform>
                                            <TransformGroup>
                                                <RotateTransform x:Name="LogoRotate" Angle="0"/>
                                                <SkewTransform x:Name="LogoSkew" AngleX="0" AngleY="0"/>
                                            </TransformGroup>
                                        </Border.RenderTransform>
                                        <Grid>
                                            <Ellipse>
                                                <Ellipse.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                                        <GradientStop Color="#5B21B6" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="X" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <TextBlock x:Name="BotStatusText" Text="Bot Idle" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="BotStatusSubtext" Text="Ready to start" FontSize="11" Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Control Buttons -->
                            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                                <Button x:Name="StartBotButton" Content="▶ START BOT" Click="StartBotButton_Click" Cursor="Hand" Margin="0,0,0,8">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" CornerRadius="10" Padding="0,12">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#10B981" Offset="0"/>
                                                        <GradientStop Color="#059669" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{TemplateBinding Content}" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="PauseBotButton" Content="⏸ Pause" Click="PauseBotButton_Click" Visibility="Collapsed" Cursor="Hand" Margin="0,0,4,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#20F59E0B" CornerRadius="8" Padding="0,10">
                                                    <TextBlock Text="{TemplateBinding Content}" FontSize="11" FontWeight="SemiBold" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button x:Name="StopBotButton" Grid.Column="1" Content="⏹ Stop" Click="StopBotButton_Click" Visibility="Collapsed" Cursor="Hand" Margin="4,0,0,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#20EF4444" CornerRadius="8" Padding="0,10">
                                                    <TextBlock Text="{TemplateBinding Content}" FontSize="11" FontWeight="SemiBold" Foreground="#EF4444" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ========== ROW 2: EXCHANGE WALLETS (Compact) ========== -->
                <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="0,0,0,15" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💰 EXCHANGE WALLETS" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                <Border x:Name="WalletUpdateBadge" Background="#2000D4FF" CornerRadius="6" Padding="6,2" Margin="10,0,0,0">
                                    <TextBlock x:Name="WalletLastUpdate" Text="Updated: --:--" FontSize="8" Foreground="#00D4FF"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Total: " FontSize="10" Foreground="#60FFFFFF" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalWalletValue" Text="$0.00" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                <Button x:Name="RefreshWalletsButton" Content="↻" Click="RefreshWallets_Click" Cursor="Hand" Margin="10,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="#15FFFFFF" CornerRadius="6" Padding="8,4">
                                                <TextBlock Text="{TemplateBinding Content}" FontSize="12" Foreground="#80FFFFFF"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#25FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Wallet Grid (Horizontal) -->
                        <ItemsControl x:Name="ExchangeWalletsList" Grid.Row="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="6" Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="3" CornerRadius="10" Padding="10,8">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#12FFFFFF" Offset="0"/>
                                                <GradientStop Color="#08FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{Binding StatusColor.Color}" Opacity="0.3"/>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <controls:ExchangeIcon ExchangeName="{Binding ExchangeName}" Size="20" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding ExchangeName}" FontSize="10" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                                <Ellipse Width="5" Height="5" Fill="{Binding StatusColor}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding USDTBalance}" FontSize="13" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- ========== ROW 3: KEY PERFORMANCE METRICS ========== -->
                <Grid Grid.Row="3" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Win Rate -->
                    <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,5,0">
                        <StackPanel>
                            <TextBlock Text="WIN RATE" FontSize="9" Foreground="#50FFFFFF"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="WinRateValue" Text="0%" FontSize="24" FontWeight="Bold" Foreground="#10B981"/>
                                <TextBlock x:Name="WinRateChange" Text="" FontSize="10" Foreground="#10B981" VerticalAlignment="Bottom" Margin="5,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="WinLossCount" Text="0W / 0L" FontSize="10" Foreground="#60FFFFFF"/>
                        </StackPanel>
                    </Border>

                    <!-- Profit Factor -->
                    <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="5,0">
                        <StackPanel>
                            <TextBlock Text="PROFIT FACTOR" FontSize="9" Foreground="#50FFFFFF"/>
                            <TextBlock x:Name="ProfitFactorValue" Text="-" FontSize="24" FontWeight="Bold" Foreground="#F59E0B" Margin="0,4,0,0"/>
                            <TextBlock Text="Gross Profit / Loss" FontSize="10" Foreground="#60FFFFFF"/>
                        </StackPanel>
                    </Border>

                    <!-- Average Win -->
                    <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="5,0">
                        <StackPanel>
                            <TextBlock Text="AVG WIN" FontSize="9" Foreground="#50FFFFFF"/>
                            <TextBlock x:Name="AvgWinValue" Text="$0.00" FontSize="24" FontWeight="Bold" Foreground="#10B981" Margin="0,4,0,0"/>
                            <TextBlock x:Name="LargestWin" Text="Best: $0.00" FontSize="10" Foreground="#60FFFFFF"/>
                        </StackPanel>
                    </Border>

                    <!-- Average Loss -->
                    <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="5,0">
                        <StackPanel>
                            <TextBlock Text="AVG LOSS" FontSize="9" Foreground="#50FFFFFF"/>
                            <TextBlock x:Name="AvgLossValue" Text="$0.00" FontSize="24" FontWeight="Bold" Foreground="#EF4444" Margin="0,4,0,0"/>
                            <TextBlock x:Name="LargestLoss" Text="Worst: $0.00" FontSize="10" Foreground="#60FFFFFF"/>
                        </StackPanel>
                    </Border>

                    <!-- Max Drawdown -->
                    <Border Grid.Column="4" Style="{StaticResource StatCard}" Margin="5,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="MAX DRAWDOWN" FontSize="9" Foreground="#50FFFFFF"/>
                                <Ellipse x:Name="DrawdownIndicator" Width="6" Height="6" Fill="#10B981" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="MaxDrawdownValue" Text="-0.00%" FontSize="24" FontWeight="Bold" Foreground="#10B981" Margin="0,4,0,0"/>
                            <TextBlock x:Name="CurrentDrawdown" Text="Current: -0.00%" FontSize="10" Foreground="#60FFFFFF"/>
                        </StackPanel>
                    </Border>

                    <!-- Execution Speed -->
                    <Border Grid.Column="5" Style="{StaticResource StatCard}" Margin="5,0,0,0">
                        <StackPanel>
                            <TextBlock Text="AVG SPEED" FontSize="9" Foreground="#50FFFFFF"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="AvgSpeedValue" Text="-" FontSize="24" FontWeight="Bold" Foreground="#00D4FF"/>
                                <TextBlock Text="ms" FontSize="12" Foreground="#60FFFFFF" VerticalAlignment="Bottom" Margin="3,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="SpeedTarget" Text="Target: &lt;500ms" FontSize="10" Foreground="#60FFFFFF"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========== ROW 4: PERFORMANCE CHART & LIVE MONITOR ========== -->
                <Grid Grid.Row="4" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                        <ColumnDefinition Width="Auto" MinWidth="320" MaxWidth="420"/>
                    </Grid.ColumnDefinitions>

                    <!-- P&L Performance Chart -->
                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="OVERALL PERFORMANCE" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                    <Border Background="#207C3AED" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                                        <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold" Foreground="#7C3AED"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <RadioButton x:Name="Chart1D" Content="1D" Style="{StaticResource TabButton}" GroupName="ChartPeriod" IsChecked="True"/>
                                    <RadioButton x:Name="Chart7D" Content="7D" Style="{StaticResource TabButton}" GroupName="ChartPeriod"/>
                                    <RadioButton x:Name="Chart30D" Content="30D" Style="{StaticResource TabButton}" GroupName="ChartPeriod"/>
                                    <RadioButton x:Name="ChartAll" Content="ALL" Style="{StaticResource TabButton}" GroupName="ChartPeriod"/>
                                </StackPanel>
                            </Grid>

                            <lvc:CartesianChart x:Name="PerformanceChart" Grid.Row="1" MinHeight="200"/>
                        </Grid>
                    </Border>

                    <!-- Live Monitor -->
                    <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="LIVE MONITOR" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                    <Border x:Name="LiveIndicatorBadge" Background="#2010B981" CornerRadius="6" Padding="6,2" Margin="10,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="LiveIndicatorDot" Width="6" Height="6" Fill="#10B981" Margin="0,0,5,0"/>
                                            <TextBlock x:Name="LiveIndicatorText" Text="IDLE" FontSize="9" FontWeight="Bold" Foreground="#10B981"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="LastUpdateTime" Text="--:--:--" FontSize="10" Foreground="#50FFFFFF" HorizontalAlignment="Right"/>
                            </Grid>

                            <StackPanel Grid.Row="1">
                                <!-- Trading Status -->
                                <Border x:Name="TradingStatusBorder" Background="#15FFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,0,12">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="TradingStatusDot" Width="10" Height="10" Fill="#808080" Margin="0,0,10,0"/>
                                            <TextBlock x:Name="TradingStatusText" Text="Waiting for bot to start..." FontSize="12" Foreground="#80FFFFFF"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ScanCount" Text="Scans: 0" FontSize="10" Foreground="#50FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Spread History -->
                                <Border Background="#10FFFFFF" CornerRadius="10" Padding="12">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock Text="SPREAD HISTORY" FontSize="9" FontWeight="Bold" Foreground="#50FFFFFF"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="SpreadMin" Text="Min: 0%" FontSize="9" Foreground="#60FFFFFF" Margin="0,0,10,0"/>
                                                <TextBlock x:Name="SpreadMax" Text="Max: 0%" FontSize="9" Foreground="#7C3AED" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                        <lvc:CartesianChart x:Name="SpreadHistoryChart" Height="80"/>
                                    </StackPanel>
                                </Border>

                                <!-- Balance Distribution (For Arbitrage Mode) -->
                                <Border x:Name="BalanceDistributionPanel" Background="#10FFFFFF" CornerRadius="10" Padding="12" Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="BALANCE DISTRIBUTION" FontSize="9" FontWeight="Bold" Foreground="#50FFFFFF" Margin="0,0,0,8"/>
                                        <Grid Height="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="ExchangeARatio" Width="50*"/>
                                                <ColumnDefinition x:Name="ExchangeBRatio" Width="50*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="4,0,0,4">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#F3BA2F" Offset="0"/>
                                                        <GradientStop Color="#F3BA2F" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border Grid.Column="1" CornerRadius="0,4,4,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#23AF91" Offset="0"/>
                                                        <GradientStop Color="#23AF91" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                        <Grid Margin="0,5,0,0">
                                            <TextBlock x:Name="ExchangeAPercent" Text="50%" FontSize="10" Foreground="#F3BA2F"/>
                                            <TextBlock x:Name="ExchangeBPercent" Text="50%" FontSize="10" Foreground="#23AF91" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ========== ROW 5: MARKET OVERVIEW & ACTIVE PAIRS ========== -->
                <Grid Grid.Row="5" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                        <ColumnDefinition Width="Auto" MinWidth="300" MaxWidth="380"/>
                    </Grid.ColumnDefinitions>

                    <!-- Market Overview -->
                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="MARKET OVERVIEW" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                    <Border Background="#2000D4FF" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                                        <TextBlock Text="REAL-TIME" FontSize="9" FontWeight="Bold" Foreground="#00D4FF"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <ItemsControl x:Name="MarketOverviewList" Grid.Row="1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#10FFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <controls:CoinIcon Symbol="{Binding Symbol}" Size="32" Margin="0,0,10,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                                        <TextBlock Text="/USDT" FontSize="11" Foreground="#60FFFFFF" VerticalAlignment="Bottom"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="9" Foreground="#60FFFFFF"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="90" Margin="0,0,15,0">
                                                    <TextBlock Text="{Binding Price}" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding Change24h}" FontSize="10" Foreground="{Binding ChangeColor}" HorizontalAlignment="Right"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" MinWidth="70" Margin="0,0,10,0">
                                                    <TextBlock Text="SPREAD" FontSize="8" Foreground="#50FFFFFF" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding BestSpread}" FontSize="13" FontWeight="Bold" Foreground="{Binding SpreadColor}" HorizontalAlignment="Center"/>
                                                </StackPanel>

                                                <Border Grid.Column="4" Background="{Binding ScoreBgColor}" CornerRadius="6" Padding="10,5">
                                                    <TextBlock Text="{Binding Score}" FontSize="11" FontWeight="Bold" Foreground="{Binding ScoreColor}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Active Trading Pairs -->
                    <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="ACTIVE PAIRS" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                <Button Content="+ Add" Style="{StaticResource ActionButton}" HorizontalAlignment="Right" Padding="10,5" Click="AddPairButton_Click"/>
                            </Grid>

                            <ItemsControl x:Name="ActivePairsList" Grid.Row="1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#15FFFFFF" CornerRadius="10" Padding="12" Margin="0,0,0,6">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <controls:CoinIcon Symbol="{Binding Symbol}" Size="28" Margin="0,0,10,0"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="White" FontSize="12"/>
                                                        <TextBlock Text="{Binding Route}" FontSize="9" Foreground="#60FFFFFF"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Background="{Binding StatusBgColor}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="Bold" Foreground="{Binding StatusColor}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Quick Actions -->
                            <Border Grid.Row="2" Background="#10FFFFFF" CornerRadius="10" Padding="12" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="EmergencyStopButton" Content="⚠ Emergency Stop" Margin="0,0,5,0" Click="EmergencyStopButton_Click" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#20EF4444" CornerRadius="8" Padding="10,8">
                                                    <TextBlock Text="{TemplateBinding Content}" FontSize="10" FontWeight="SemiBold" Foreground="#EF4444" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="RefreshButton" Grid.Column="1" Content="↻ Refresh" Margin="5,0,0,0" Click="RefreshButton_Click" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#2000D4FF" CornerRadius="8" Padding="10,8">
                                                    <TextBlock Text="{TemplateBinding Content}" FontSize="10" FontWeight="SemiBold" Foreground="#00D4FF" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ========== ROW 6: RECENT TRADES & ACTIVITY LOG ========== -->
                <Grid Grid.Row="6" MinHeight="280">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="350"/>
                        <ColumnDefinition Width="Auto" MinWidth="320" MaxWidth="400"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent Trades -->
                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="RECENT TRADES" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="RecentTradesCount" Text="(0)" FontSize="11" Foreground="#50FFFFFF" Margin="8,0,0,0"/>
                                </StackPanel>
                                <Button Content="View All" Style="{StaticResource ActionButton}" HorizontalAlignment="Right" Padding="12,6" Click="ViewAllTradesButton_Click"/>
                            </Grid>

                            <ScrollViewer Grid.Row="1" Style="{StaticResource PremiumScrollViewer}" MaxHeight="220">
                                <ItemsControl x:Name="RecentTradesList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding BackgroundColor}" CornerRadius="10" Padding="12,10" Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <controls:CoinIcon Symbol="{Binding Symbol}" Size="28" Margin="0,0,10,0"/>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Symbol}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                            <TextBlock Text="/USDT" FontSize="10" Foreground="#60FFFFFF" VerticalAlignment="Bottom"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Route}" FontSize="9" Foreground="#60FFFFFF"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="70">
                                                        <TextBlock Text="{Binding Time}" FontSize="9" Foreground="#80FFFFFF" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding Spread}" FontSize="9" Foreground="#7C3AED" HorizontalAlignment="Right"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" MinWidth="70">
                                                        <TextBlock Text="{Binding PnL}" FontSize="14" FontWeight="Bold" Foreground="{Binding PnLColor}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding ExecutionTime}" FontSize="8" Foreground="#60FFFFFF" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Activity Log -->
                    <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ACTIVITY LOG" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                    <Border x:Name="NewActivityBadge" Background="#20EF4444" CornerRadius="8" Padding="6,2" Margin="10,0,0,0" Visibility="Collapsed">
                                        <TextBlock x:Name="NewActivityCount" Text="3 new" FontSize="9" FontWeight="Bold" Foreground="#EF4444"/>
                                    </Border>
                                </StackPanel>
                                <Button Content="Clear" Cursor="Hand" HorizontalAlignment="Right" Click="ClearLogButton_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" FontSize="11" Foreground="#60FFFFFF" Cursor="Hand">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="#7C3AED"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1" Style="{StaticResource PremiumScrollViewer}" MaxHeight="220">
                                <ItemsControl x:Name="ActivityLogList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#08FFFFFF" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Ellipse Width="8" Height="8" Fill="{Binding IconColor}" Margin="0,5,10,0" VerticalAlignment="Top"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Message}" FontSize="11" Foreground="White" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Details}" FontSize="9" Foreground="#50FFFFFF" TextWrapping="Wrap" Margin="0,2,0,0" Visibility="{Binding DetailsVisibility}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding Time}" FontSize="9" Foreground="#40FFFFFF" VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Hidden elements for compatibility (kept for code-behind) -->
                <Border x:Name="CurrentModeBorder" Visibility="Collapsed"/>
                <TextBlock x:Name="CurrentModeIcon" Visibility="Collapsed"/>
                <TextBlock x:Name="CurrentModeName" Visibility="Collapsed"/>
                <TextBlock x:Name="CurrentModeNameThai" Visibility="Collapsed"/>
                <TextBlock x:Name="CurrentModeDescription" Visibility="Collapsed"/>
                <Border x:Name="TransferTypeIndicator" Visibility="Collapsed"/>
                <TextBlock x:Name="TransferTypeIcon" Visibility="Collapsed"/>
                <TextBlock x:Name="TransferTypeName" Visibility="Collapsed"/>
                <TextBlock x:Name="DashboardSessionPnL" Visibility="Collapsed"/>

                <!-- Hidden Best/Worst Pair elements (kept for code-behind compatibility) -->
                <TextBlock x:Name="BestPairSymbol" Visibility="Collapsed"/>
                <TextBlock x:Name="BestPairRoute" Visibility="Collapsed"/>
                <TextBlock x:Name="BestPairPnL" Visibility="Collapsed"/>
                <TextBlock x:Name="BestPairChange" Visibility="Collapsed"/>
                <TextBlock x:Name="BestPairRank" Visibility="Collapsed"/>
                <controls:CoinIcon x:Name="BestPairIcon" Visibility="Collapsed"/>
                <lvc:CartesianChart x:Name="BestPairChart" Visibility="Collapsed"/>
                <TextBlock x:Name="WorstPairSymbol" Visibility="Collapsed"/>
                <TextBlock x:Name="WorstPairRoute" Visibility="Collapsed"/>
                <TextBlock x:Name="WorstPairPnL" Visibility="Collapsed"/>
                <TextBlock x:Name="WorstPairChange" Visibility="Collapsed"/>
                <TextBlock x:Name="WorstPairRank" Visibility="Collapsed"/>
                <controls:CoinIcon x:Name="WorstPairIcon" Visibility="Collapsed"/>
                <lvc:CartesianChart x:Name="WorstPairChart" Visibility="Collapsed"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
