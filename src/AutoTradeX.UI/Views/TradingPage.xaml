<UserControl x:Class="AutoTradeX.UI.Views.TradingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AutoTradeX.UI.Controls">

    <UserControl.Resources>
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#20FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style x:Key="SmallActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#00D4FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="25"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                     Content="{TemplateBinding SelectionBoxItem}"
                                                     ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                     VerticalAlignment="Center"
                                                     Margin="8,0,0,0"/>
                                    <Path Grid.Column="1"
                                          Data="M0,0 L4,4 L8,0"
                                          Stroke="#80FFFFFF"
                                          StrokeThickness="1.5"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                 IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Focusable="False"
                                                 ClickMode="Press"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="#1A1A2E"
                                        BorderBrush="#40FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2A2A45"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#353555"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeTagStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <!-- Premium ScrollBar Styles -->
        <Style x:Key="PremiumScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4" MinHeight="30" Width="6" HorizontalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="0.5"/>
                                    <GradientStop Color="#6D28D9" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="8" Margin="2,4,4,4">
                            <Border Background="#10FFFFFF" CornerRadius="4" Width="6" HorizontalAlignment="Center"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Width="8">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource PremiumScrollBarThumb}" Width="6"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumScrollViewer" TargetType="ScrollViewer">
            <Setter Property="CanContentScroll" Value="False"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Column="0"
                                                    CanContentScroll="False"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    Content="{TemplateBinding Content}"
                                                    Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource PremiumScrollBar}"
                                       Minimum="0"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Not Connected Overlay -->
        <Border x:Name="NotConnectedOverlay" Visibility="Collapsed" Panel.ZIndex="100">
            <Border.Background>
                <SolidColorBrush Color="#0A0A1A" Opacity="0.95"/>
            </Border.Background>
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border CornerRadius="16" Padding="40,30" MaxWidth="450">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#20FFFFFF" Offset="0"/>
                            <GradientStop Color="#10FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#EF4444" Opacity="0.3"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel HorizontalAlignment="Center">
                        <Border Background="#20EF4444" CornerRadius="40" Width="70" Height="70" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="⚠️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ยังไม่ได้เชื่อมต่อ Exchange" FontSize="18" FontWeight="Bold"
                                   Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="กรุณากรอก API Key ในหน้าตั้งค่าเพื่อเริ่มต้นเทรด" FontSize="12"
                                   Foreground="#80FFFFFF" HorizontalAlignment="Center" TextWrapping="Wrap"
                                   TextAlignment="Center" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border Background="#15FFFFFF" CornerRadius="8" Padding="8" Margin="4,0">
                                <controls:ExchangeIcon ExchangeName="Binance" Size="28"/>
                            </Border>
                            <Border Background="#15FFFFFF" CornerRadius="8" Padding="8" Margin="4,0">
                                <controls:ExchangeIcon ExchangeName="KuCoin" Size="28"/>
                            </Border>
                            <Border Background="#15FFFFFF" CornerRadius="8" Padding="8" Margin="4,0">
                                <controls:ExchangeIcon ExchangeName="OKX" Size="28"/>
                            </Border>
                            <Border Background="#15FFFFFF" CornerRadius="8" Padding="8" Margin="4,0">
                                <controls:ExchangeIcon ExchangeName="Bybit" Size="28"/>
                            </Border>
                        </StackPanel>
                        <Button x:Name="GoToSettingsButton" Click="GoToSettings_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" CornerRadius="10" Padding="25,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C3AED" Offset="0"/>
                                                <GradientStop Color="#5B21B6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="⚙️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="ไปหน้าตั้งค่า API" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Trading Content -->
        <Grid x:Name="MainTradingContent" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Scanner -->
            <ScrollViewer Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource PremiumScrollViewer}">
                <StackPanel>
                    <!-- Scanner Panel -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="🔍 SCANNER" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Ellipse x:Name="ScannerStatusDot" Width="6" Height="6" Fill="#808080" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ScannerStatusText" Text="Idle" FontSize="9" Foreground="#808080"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="StartScanButton" Content="▶ START" Grid.Column="0" Margin="0,0,4,0"
                                        Style="{StaticResource SmallActionButton}" Click="StartScanButton_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#059669" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                                <Button x:Name="StopScanButton" Content="⏹ STOP" Grid.Column="1" Margin="4,0,0,0"
                                        Visibility="Collapsed" Style="{StaticResource SmallActionButton}" Click="StopScanButton_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EF4444" Offset="0"/>
                                            <GradientStop Color="#DC2626" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Scans" FontSize="8" Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ScanCountDisplay" Text="0" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Found" FontSize="8" Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="OpportunityCountDisplay" Text="0" FontSize="14" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Best" FontSize="8" Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="BestScoreDisplay" Text="0" FontSize="14" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Strategy:" FontSize="9" Foreground="#60FFFFFF" Margin="0,0,0,4"/>
                            <ComboBox x:Name="StrategyCombo" SelectedIndex="0" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="StrategyCombo_SelectionChanged">
                                <ComboBoxItem Content="💰 Arbitrage"/>
                                <ComboBoxItem Content="📉 Price Drop"/>
                                <ComboBoxItem Content="📊 Volatility"/>
                                <ComboBoxItem Content="📈 Volume"/>
                                <ComboBoxItem Content="🚀 Momentum"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Scan Results -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="RESULTS" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                    <Border x:Name="RecommendedBadge" Background="#7C3AED" CornerRadius="6" Padding="5,2" Margin="6,0,0,0" Visibility="Collapsed">
                                        <TextBlock Text="🔥 HOT" FontSize="7" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <Button x:Name="AddPairButton" Content="+" HorizontalAlignment="Right"
                                        Background="#7C3AED" Click="AddPairButton_Click" Style="{StaticResource SmallActionButton}"
                                        Padding="8,4" FontSize="12" Width="28" Height="28"/>
                            </Grid>

                            <ItemsControl x:Name="ScanResultsList" MaxHeight="180">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#10FFFFFF" CornerRadius="6" Padding="8" Margin="0,0,0,4" Cursor="Hand"
                                                MouseLeftButtonDown="ScanResult_Click" Tag="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <controls:CoinIcon Symbol="{Binding BaseAsset}" Size="24" Margin="0,0,6,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" Foreground="White" FontSize="11"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding BestBuyExchange}" FontSize="8" Foreground="#F3BA2F"/>
                                                        <TextBlock Text=" → " FontSize="8" Foreground="#40FFFFFF"/>
                                                        <TextBlock Text="{Binding BestSellExchange}" FontSize="8" Foreground="#23AF91"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding SpreadDisplay}" FontSize="12" FontWeight="Bold"
                                                           Foreground="{Binding SpreadColor}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border x:Name="ScanEmptyState" Background="#08FFFFFF" CornerRadius="6" Padding="12" Margin="0,4,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Click START to scan" FontSize="10" Foreground="#60FFFFFF" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="ScanLoadingState" Visibility="Collapsed" Background="#08FFFFFF" CornerRadius="6" Padding="12" Margin="0,4,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="ScanLoadingIcon" Text="⏳" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ScanLoadingText" Text="Scanning..." FontSize="10" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Active Pairs -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="ACTIVE PAIRS" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,8"/>
                            <ListBox x:Name="TradingPairsList" Background="Transparent" BorderThickness="0"
                                     SelectionChanged="TradingPairsList_SelectionChanged"
                                     ItemsSource="{Binding TradingPairs}" MaxHeight="120">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#10FFFFFF" CornerRadius="6" Padding="8" Margin="0,0,0,4" Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <controls:CoinIcon Symbol="{Binding BaseAsset}" Size="24" Margin="0,0,6,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" Foreground="White" FontSize="10"/>
                                                    <TextBlock FontSize="8" Foreground="#60FFFFFF">
                                                        <Run Text="{Binding ExchangeA}"/>
                                                        <Run Text=" → "/>
                                                        <Run Text="{Binding ExchangeB}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding CurrentSpread, StringFormat={}{0:F2}%}"
                                                           FontWeight="Bold" FontSize="10" Foreground="{Binding SpreadColor}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Quick Actions -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="QUICK ACTIONS" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ScanAllButton" Content="↻ Refresh" Grid.Column="0" Margin="0,0,4,0"
                                        Style="{StaticResource SmallActionButton}" Click="ScanAllButton_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00D4FF" Offset="0"/>
                                            <GradientStop Color="#0099CC" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                                <Button x:Name="PauseAllButton" Content="⏸ Pause" Grid.Column="1" Margin="4,0,0,0"
                                        Style="{StaticResource SmallActionButton}" Click="PauseAllButton_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#D97706" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                            </Grid>
                            <Button x:Name="EmergencyStopButton" Content="🛑 EMERGENCY STOP" Margin="0,6,0,0"
                                    Style="{StaticResource SmallActionButton}" Click="EmergencyStopButton_Click">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EF4444" Offset="0"/>
                                        <GradientStop Color="#DC2626" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Center Panel - Main Trading View -->
            <ScrollViewer Grid.Column="1" Margin="10,0" Style="{StaticResource PremiumScrollViewer}">
                <StackPanel>
                    <!-- Selected Pair Header -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <controls:CoinIcon x:Name="SelectedCoinIcon" Symbol="BTC" Size="40" Margin="0,0,12,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="SelectedPairName" Text="BTC/USDT" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock x:Name="SelectedPairExchanges" Text="Binance → KuCoin" FontSize="11" Foreground="#60FFFFFF"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Spread: " FontSize="12" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SelectedSpread" Text="0.15%" FontSize="22" FontWeight="Bold" Foreground="#10B981"/>
                                </StackPanel>
                                <TextBlock x:Name="SelectedProfitEstimate" Text="Est: $12.50/trade" FontSize="10" Foreground="#60FFFFFF" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Exchange Comparison -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Exchange A (Buy) -->
                            <Border Grid.Column="0" Background="#08F3BA2F" CornerRadius="10" Padding="12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <controls:ExchangeIcon x:Name="ExchangeAIcon" ExchangeName="Binance" Size="28" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="ExchangeAName" Text="BINANCE" FontSize="12" FontWeight="Bold" Foreground="#F3BA2F"/>
                                            <TextBlock Text="BUY" FontSize="9" Foreground="#10B981"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Style="{StaticResource ModeTagStyle}" Background="#2010B981">
                                            <TextBlock Text="SPOT" FontSize="8" FontWeight="Bold" Foreground="#10B981"/>
                                        </Border>
                                        <Border x:Name="ExchangeAFutures" Style="{StaticResource ModeTagStyle}" Background="#20F59E0B">
                                            <TextBlock Text="FUTURES" FontSize="8" FontWeight="Bold" Foreground="#F59E0B"/>
                                        </Border>
                                        <Border x:Name="ExchangeAMargin" Style="{StaticResource ModeTagStyle}" Background="#207C3AED">
                                            <TextBlock Text="MARGIN" FontSize="8" FontWeight="Bold" Foreground="#7C3AED"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="ExchangeAPrice" Text="$0.00" FontSize="22" FontWeight="Bold" Foreground="White"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="BID" FontSize="8" Foreground="#50FFFFFF"/>
                                            <TextBlock x:Name="ExchangeABid" Text="$0.00" FontSize="11" Foreground="#10B981" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="ASK" FontSize="8" Foreground="#50FFFFFF"/>
                                            <TextBlock x:Name="ExchangeAAsk" Text="$0.00" FontSize="11" Foreground="#EF4444" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="#10FFFFFF" CornerRadius="6" Padding="8,6" Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="BALANCE" FontSize="7" Foreground="#50FFFFFF"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="ExchangeABalance" Text="0.00" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="ExchangeABalanceAsset" Text=" USDT" FontSize="9" Foreground="#60FFFFFF" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Center Arrow -->
                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <Path Data="M0,5 L10,0 L10,3 L30,3 L30,7 L10,7 L10,10 Z" Fill="#7C3AED" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ARB" FontSize="8" FontWeight="Bold" Foreground="#7C3AED" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    <Border Background="#207C3AED" CornerRadius="4" Padding="6,3" Margin="0,5,0,0">
                                        <TextBlock x:Name="CenterSpreadDisplay" Text="0.15%" FontSize="10" FontWeight="Bold" Foreground="#00D4FF"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Exchange B (Sell) -->
                            <Border Grid.Column="2" Background="#0823AF91" CornerRadius="10" Padding="12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <controls:ExchangeIcon x:Name="ExchangeBIcon" ExchangeName="KuCoin" Size="28" Margin="0,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="ExchangeBName" Text="KUCOIN" FontSize="12" FontWeight="Bold" Foreground="#23AF91"/>
                                            <TextBlock Text="SELL" FontSize="9" Foreground="#EF4444"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel x:Name="ExchangeBModesPanel" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Style="{StaticResource ModeTagStyle}" Background="#2010B981">
                                            <TextBlock Text="SPOT" FontSize="8" FontWeight="Bold" Foreground="#10B981"/>
                                        </Border>
                                        <Border x:Name="ExchangeBFutures" Style="{StaticResource ModeTagStyle}" Background="#20F59E0B">
                                            <TextBlock Text="FUTURES" FontSize="8" FontWeight="Bold" Foreground="#F59E0B"/>
                                        </Border>
                                        <Border x:Name="ExchangeBMargin" Style="{StaticResource ModeTagStyle}" Background="#207C3AED" Visibility="Collapsed">
                                            <TextBlock Text="MARGIN" FontSize="8" FontWeight="Bold" Foreground="#7C3AED"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="ExchangeBPrice" Text="$0.00" FontSize="22" FontWeight="Bold" Foreground="White"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="BID" FontSize="8" Foreground="#50FFFFFF"/>
                                            <TextBlock x:Name="ExchangeBBid" Text="$0.00" FontSize="11" Foreground="#10B981" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="ASK" FontSize="8" Foreground="#50FFFFFF"/>
                                            <TextBlock x:Name="ExchangeBAsk" Text="$0.00" FontSize="11" Foreground="#EF4444" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="#10FFFFFF" CornerRadius="6" Padding="8,6" Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="BALANCE" FontSize="7" Foreground="#50FFFFFF"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="ExchangeBBalance" Text="0.00" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="ExchangeBBalanceAsset" Text=" USDT" FontSize="9" Foreground="#60FFFFFF" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Arbitrage Mode Selector -->
                    <controls:ArbitrageModeSelector x:Name="ModeSelector" Margin="0,0,0,10"
                                                    ModeChanged="ModeSelector_ModeChanged"
                                                    TransferTypeChanged="ModeSelector_TransferTypeChanged"/>

                    <!-- P&L Display -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="PROFIT / LOSS" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                <TextBlock x:Name="PnLSourceText" Text="(This Session)" FontSize="8" Foreground="#40FFFFFF" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Session" FontSize="8" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="SessionPnL" Text="+$0.00" FontSize="16" FontWeight="Bold" Foreground="#10B981"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Today" FontSize="8" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="TodayPnL" Text="+$0.00" FontSize="16" FontWeight="Bold" Foreground="#10B981"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                    <TextBlock Text="Trades" FontSize="8" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="TradeCount" Text="0" FontSize="16" FontWeight="Bold" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#08FFFFFF" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="USDT: " FontSize="10" Foreground="#80FFFFFF"/>
                                        <TextBlock x:Name="USDTChangeText" Text="+0.00" FontSize="10" FontWeight="SemiBold" Foreground="#10B981"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock x:Name="BaseAssetLabel" Text="BTC: " FontSize="10" Foreground="#80FFFFFF"/>
                                        <TextBlock x:Name="BaseAssetChangeText" Text="+0.00000000" FontSize="10" FontWeight="SemiBold" Foreground="#10B981"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Transfer Progress Panel -->
                    <Border x:Name="TransferProgressPanel" Style="{StaticResource GlassCard}" Margin="0,0,0,10" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="🔄 TRANSFER IN PROGRESS" FontSize="10" FontWeight="Bold" Foreground="#F59E0B"/>
                                <Button x:Name="CancelTransferButton" Content="Cancel" HorizontalAlignment="Right"
                                        Click="CancelTransferButton_Click" Style="{StaticResource SmallActionButton}" Padding="10,4">
                                    <Button.Background>
                                        <SolidColorBrush Color="#EF4444"/>
                                    </Button.Background>
                                </Button>
                            </Grid>
                            <StackPanel>
                                <Grid Margin="0,4,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="Step1Icon" Text="✓" FontSize="10" Foreground="#10B981" Width="18"/>
                                        <TextBlock Text="Buy Order Filled" FontSize="10" Foreground="White"/>
                                    </StackPanel>
                                    <TextBlock x:Name="Step1Details" Text="0.05 BTC @ $98,500" FontSize="9" Foreground="#60FFFFFF" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,4,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="Step2Icon" Text="⏳" FontSize="10" Foreground="#F59E0B" Width="18"/>
                                        <TextBlock Text="Withdrawal" FontSize="10" Foreground="White"/>
                                    </StackPanel>
                                    <TextBlock x:Name="Step2Details" Text="Pending..." FontSize="9" Foreground="#60FFFFFF" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,4,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="Step3Icon" Text="○" FontSize="10" Foreground="#60FFFFFF" Width="18"/>
                                        <TextBlock Text="Blockchain Transfer" FontSize="10" Foreground="#60FFFFFF"/>
                                    </StackPanel>
                                    <TextBlock x:Name="Step3Details" Text="2/6 confirms" FontSize="9" Foreground="#60FFFFFF" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,4,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="Step4Icon" Text="○" FontSize="10" Foreground="#60FFFFFF" Width="18"/>
                                        <TextBlock Text="Deposit &amp; Sell" FontSize="10" Foreground="#60FFFFFF"/>
                                    </StackPanel>
                                    <TextBlock x:Name="Step4Details" Text="Waiting..." FontSize="9" Foreground="#60FFFFFF" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                            <Border Background="#15F59E0B" CornerRadius="6" Padding="10" Margin="0,8,0,0">
                                <Grid>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Buy: " FontSize="9" Foreground="#80FFFFFF"/>
                                            <TextBlock x:Name="TransferBuyPrice" Text="$98,500" FontSize="9" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Current: " FontSize="9" Foreground="#80FFFFFF"/>
                                            <TextBlock x:Name="TransferCurrentPrice" Text="$98,650" FontSize="9" Foreground="#10B981"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="Fee: " FontSize="9" Foreground="#80FFFFFF"/>
                                            <TextBlock x:Name="TransferFeeDisplay" Text="0.0005 BTC" FontSize="9" Foreground="#F59E0B"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right">
                                        <TextBlock Text="Unrealized" FontSize="8" Foreground="#60FFFFFF"/>
                                        <TextBlock x:Name="TransferUnrealizedPnL" Text="+$7.50" FontSize="14" FontWeight="Bold" Foreground="#10B981"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Manual Transfer Confirmation Button -->
                            <Button x:Name="ConfirmTransferButton" Visibility="Collapsed"
                                    Margin="0,8,0,0" Style="{StaticResource ActionButton}"
                                    Click="ConfirmTransferButton_Click">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="✓ " FontSize="13"/>
                                    <TextBlock Text="I've Transferred / ฉันโอนแล้ว" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Trade Controls -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="TRADE AMOUNT" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TradeAmountInput" Text="100" Style="{StaticResource DarkTextBox}" FontSize="16" FontWeight="SemiBold"/>
                                <ComboBox x:Name="TradeAmountUnit" Grid.Column="1" Width="80" Margin="8,0,0,0"
                                          SelectedIndex="0" Style="{StaticResource DarkComboBox}">
                                    <ComboBoxItem Content="USDT"/>
                                    <ComboBoxItem Content="BTC"/>
                                    <ComboBoxItem Content="%"/>
                                </ComboBox>
                            </Grid>
                            <TextBlock x:Name="EstimatedProfit" Text="Est. Profit: $0.15" FontSize="11" Foreground="#10B981" Margin="0,8,0,0"/>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ManualTradeButton" Content="Execute Trade" Grid.Column="0" Margin="0,0,5,0"
                                        Style="{StaticResource ActionButton}" Click="ManualTradeButton_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#059669" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                                <Button x:Name="AutoTradeToggle" Content="Auto: OFF" Grid.Column="1" Margin="5,0,0,0"
                                        Style="{StaticResource ActionButton}" Click="AutoTradeToggle_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#5B21B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Panel - Order Book & Executions -->
            <ScrollViewer Grid.Column="2" Margin="10,0,0,0" Style="{StaticResource PremiumScrollViewer}">
                <StackPanel>
                    <!-- Order Book -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="ORDER BOOK" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,10"/>

                            <TextBlock Text="ASKS" FontSize="8" Foreground="#EF4444" Margin="0,0,0,4"/>
                            <ItemsControl x:Name="AsksDisplay">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#15EF4444" Height="18" HorizontalAlignment="Right"
                                                    Width="{Binding DepthPercent}" CornerRadius="2" Grid.ColumnSpan="3"/>
                                            <TextBlock Text="{Binding Price, StringFormat=F2}" Foreground="#EF4444" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=F4}" Foreground="#80FFFFFF" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Total, StringFormat=F2}" Foreground="#60FFFFFF" FontSize="10" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="#15FFFFFF" CornerRadius="4" Padding="8,6" Margin="0,8">
                                <Grid>
                                    <TextBlock Text="SPREAD" FontSize="9" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="OrderBookSpread" Text="$0.00 (0.00%)" FontSize="10" FontWeight="Bold" Foreground="#7C3AED" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="BIDS" FontSize="8" Foreground="#10B981" Margin="0,0,0,4"/>
                            <ItemsControl x:Name="BidsDisplay">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#1510B981" Height="18" HorizontalAlignment="Left"
                                                    Width="{Binding DepthPercent}" CornerRadius="2" Grid.ColumnSpan="3"/>
                                            <TextBlock Text="{Binding Price, StringFormat=F2}" Foreground="#10B981" FontSize="10"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=F4}" Foreground="#80FFFFFF" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Total, StringFormat=F2}" Foreground="#60FFFFFF" FontSize="10" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Recent Executions -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="RECENT TRADES" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,10"/>
                            <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding RecentExecutions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#10FFFFFF" CornerRadius="6" Padding="8" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold" Foreground="White" FontSize="10"/>
                                                        <TextBlock Text="{Binding TimeAgo}" FontSize="8" Foreground="#60FFFFFF"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding PnLDisplay}" FontWeight="Bold" FontSize="11"
                                                                   Foreground="{Binding PnLColor}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding ExecutionTime}" FontSize="8"
                                                                   Foreground="#60FFFFFF" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
