                                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                <TextBox x:Name="ProfitTargetInput" Text="5" Width="35" FontSize="10"
                                                         Background="#20FFFFFF" BorderThickness="0" Foreground="White"
                                                         TextAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                                                <TextBlock Text="%" FontSize="10" Foreground="#80FFFFFF" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🛑 หยุดขาดทุน" FontSize="10" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                <TextBox x:Name="MaxLossInput" Text="3" Width="35" FontSize="10"
                                                         Background="#20FFFFFF" BorderThickness="0" Foreground="White"
                                                         TextAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                                                <TextBlock Text="%" FontSize="10" Foreground="#80FFFFFF" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="📊 เทรด/ชม." FontSize="10" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="MaxTradesCombo" Grid.Column="1" SelectedIndex="1" Width="55" FontSize="9" Background="#20FFFFFF">
                                                <ComboBoxItem Content="5"/>
                                                <ComboBoxItem Content="10"/>
                                                <ComboBoxItem Content="20"/>
                                                <ComboBoxItem Content="∞"/>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Section 3: Trade Actions -->
                                <Border Background="#15FFFFFF" CornerRadius="12" Padding="15" Margin="0,0,0,10" MinWidth="180">
                                    <StackPanel>
                                        <TextBlock Text="⚡ TRADE ACTIONS" FontSize="10" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,10"/>

                                        <!-- AI Toggle Button - Premium -->
                                        <Button x:Name="AITradeToggle" Padding="16,14" FontSize="13" FontWeight="Bold"
                                                Style="{StaticResource ActionButton}" Click="AITradeToggle_Click" Margin="0,0,0,10">
                                            <Button.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                                    <GradientStop Color="#5B21B6" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Button.Background>
                                            <Button.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.5" Color="#7C3AED"/>
                                            </Button.Effect>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="AIToggleIcon" Text="▶" FontSize="11" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="AIToggleText" Text="START AI"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Running Indicator -->
                                        <Border x:Name="AIRunningIndicator" Visibility="Collapsed" Background="#1510B981"
                                                CornerRadius="8" Padding="10,6" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Ellipse x:Name="PulseIndicator" Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0">
                                                    <Ellipse.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="1" To="0.3" Duration="0:0:0.8"
                                                                                     AutoReverse="True"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Ellipse.Triggers>
                                                </Ellipse>
                                                <TextBlock x:Name="AIRunningText" Text="AI กำลังทำงาน..." FontSize="9" Foreground="#10B981" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Manual Trade Buttons -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ManualBuyBtn" Content="▲ BUY" Padding="6,8" FontSize="10" FontWeight="Bold"
                                                    Style="{StaticResource ActionButton}" Click="ManualBuy_Click" Margin="0,0,3,0">
                                                <Button.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#10B981" Offset="0"/>
                                                        <GradientStop Color="#059669" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Button.Background>
                                            </Button>
                                            <Button x:Name="ManualSellBtn" Grid.Column="1" Content="▼ SELL" Padding="6,8" FontSize="10" FontWeight="Bold"
                                                    Style="{StaticResource ActionButton}" Click="ManualSell_Click" Margin="3,0,0,0">
                                                <Button.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#EF4444" Offset="0"/>
                                                        <GradientStop Color="#DC2626" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Button.Background>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </WrapPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right Panel - Position & Stats -->
            <ScrollViewer Style="{StaticResource PremiumScrollViewer}" Grid.Column="2" Margin="10,0,0,0" MaxWidth="380">
                <StackPanel>
                    <!-- Current Position -->
                    <Border x:Name="PositionCard" Style="{StaticResource GlassCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="CURRENT POSITION / Position ปัจจุบัน" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                <Border x:Name="PositionStatusBadge" Background="#20F59E0B" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                                    <TextBlock x:Name="PositionStatusText" Text="NO POSITION" FontSize="9" FontWeight="Bold" Foreground="#F59E0B"/>
                                </Border>
                            </Grid>

                            <!-- Position Info (hidden when no position) -->
                            <StackPanel x:Name="PositionInfo" Visibility="Collapsed">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Entry Price" FontSize="9" Foreground="#60FFFFFF"/>
                                        <TextBlock x:Name="PositionEntryPrice" Text="$0.00" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Current Price" FontSize="9" Foreground="#60FFFFFF"/>
                                        <TextBlock x:Name="PositionCurrentPrice" Text="$0.00" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Size" FontSize="9" Foreground="#60FFFFFF"/>
                                        <TextBlock x:Name="PositionSize" Text="0" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Value" FontSize="9" Foreground="#60FFFFFF"/>
                                        <TextBlock x:Name="PositionValue" Text="$0.00" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Unrealized PnL -->
                                <Border Background="#15FFFFFF" CornerRadius="10" Padding="12">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="Unrealized P&amp;L" FontSize="10" Foreground="#60FFFFFF"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="PositionPnL" Text="+$0.00" FontSize="20" FontWeight="Bold" Foreground="#10B981"/>
                                                <TextBlock x:Name="PositionPnLPercent" Text=" (+0.00%)" FontSize="14" Foreground="#10B981" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button x:Name="ClosePositionBtn" Content="CLOSE" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Padding="15,8" FontSize="11" Style="{StaticResource ActionButton}" Click="ClosePosition_Click">
                                            <Button.Background><SolidColorBrush Color="#EF4444"/></Button.Background>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Take Profit / Stop Loss Levels -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#1510B981" CornerRadius="6" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="Take Profit" FontSize="9" Foreground="#10B981"/>
                                            <TextBlock x:Name="PositionTP" Text="$0.00" FontSize="12" FontWeight="SemiBold" Foreground="#10B981"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#15EF4444" CornerRadius="6" Padding="8" Margin="5,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Stop Loss" FontSize="9" Foreground="#EF4444"/>
                                            <TextBlock x:Name="PositionSL" Text="$0.00" FontSize="12" FontWeight="SemiBold" Foreground="#EF4444"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <!-- No Position Message -->
                            <TextBlock x:Name="NoPositionText" Text="No active position. Click START AI or MANUAL BUY to enter."
                                       FontSize="11" Foreground="#60FFFFFF" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Session Statistics -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="SESSION STATS / สถิติรอบนี้" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Total P&amp;L" FontSize="9" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="SessionPnL" Text="+$0.00" FontSize="18" FontWeight="Bold" Foreground="#10B981"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,0,10">
                                    <TextBlock Text="Win Rate" FontSize="9" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="SessionWinRate" Text="0%" FontSize="18" FontWeight="Bold" Foreground="#00D4FF"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <TextBlock Text="Total Trades" FontSize="9" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="SessionTrades" Text="0" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                    <TextBlock Text="Win/Lose" FontSize="9" Foreground="#60FFFFFF"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="SessionWins" Text="0" FontSize="14" FontWeight="SemiBold" Foreground="#10B981"/>
                                        <TextBlock Text=" / " FontSize="14" Foreground="#60FFFFFF"/>
                                        <TextBlock x:Name="SessionLosses" Text="0" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Profit Factor" FontSize="9" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="SessionProfitFactor" Text="0.00" FontSize="14" FontWeight="SemiBold" Foreground="#7C3AED"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <TextBlock Text="Max Drawdown" FontSize="9" Foreground="#60FFFFFF"/>
                                    <TextBlock x:Name="SessionDrawdown" Text="0%" FontSize="14" FontWeight="SemiBold" Foreground="#F59E0B"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Technical Indicators -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="INDICATORS / ตัวชี้วัด" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,15"/>

                            <ItemsControl x:Name="IndicatorsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#10FFFFFF" CornerRadius="8" Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ShortName}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="9" Foreground="#60FFFFFF" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Value, StringFormat=N2}" FontSize="12"
                                                           Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <Border Grid.Column="2" CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#20F59E0B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Bullish">
                                                                    <Setter Property="Background" Value="#2010B981"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Bearish">
                                                                    <Setter Property="Background" Value="#20EF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Bullish">
                                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Bearish">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Emergency Stop -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="RISK MANAGEMENT / จัดการความเสี่ยง" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,15"/>

                            <!-- Daily Loss Display -->
                            <Border Background="#15EF4444" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Daily Loss Limit" FontSize="9" Foreground="#EF4444"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="DailyLoss" Text="$0.00" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text=" / " FontSize="14" Foreground="#60FFFFFF"/>
                                            <TextBlock x:Name="DailyLossLimit" Text="$50.00" FontSize="14" Foreground="#EF4444"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Emergency Stop Button -->
                            <Button x:Name="EmergencyStopBtn" Cursor="Hand" Click="EmergencyStop_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="emergencyBorder" CornerRadius="12" Padding="0,14">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#EF4444" Offset="0"/>
                                                    <GradientStop Color="#DC2626" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.5" Color="#EF4444"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="🛑" FontSize="16" Margin="0,0,8,0" Foreground="White" VerticalAlignment="Center"/>
                                                <TextBlock Text="EMERGENCY STOP" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="emergencyBorder" Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#F87171" Offset="0"/>
                                                            <GradientStop Color="#EF4444" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Text="Immediately closes all positions and stops AI trading"
                                       FontSize="9" Foreground="#60FFFFFF" TextAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
