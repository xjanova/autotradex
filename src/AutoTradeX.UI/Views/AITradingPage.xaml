<UserControl x:Class="AutoTradeX.UI.Views.AITradingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AutoTradeX.UI.Controls">

    <UserControl.Resources>
        <!-- Glass Card Style -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#20FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Exchange Tab Style -->
        <Style x:Key="ExchangeTabStyle" TargetType="Border">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Selected Exchange Tab -->
        <Style x:Key="SelectedExchangeTab" TargetType="Border" BasedOn="{StaticResource ExchangeTabStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C3AED" Offset="0"/>
                        <GradientStop Color="#5B21B6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.5" Color="#7C3AED"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Strategy Card Style -->
        <Style x:Key="StrategyCard" TargetType="Border">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="10" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TextBox Style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#00D4FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active Pair Tab Style -->
        <Style x:Key="ActivePairTabStyle" TargetType="Border">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>

        <!-- Selected Pair Tab -->
        <Style x:Key="SelectedPairTab" TargetType="Border" BasedOn="{StaticResource ActivePairTabStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#7C3AED" Offset="0"/>
                        <GradientStop Color="#6D28D9" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium ScrollBar Thumb Style -->
        <Style x:Key="PremiumScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumb" CornerRadius="5" MinHeight="40" Width="8" HorizontalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="0.5"/>
                                    <GradientStop Color="#6D28D9" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.6" Color="#7C3AED"/>
                            </Border.Effect>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium ScrollBar Style -->
        <Style x:Key="PremiumScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Width="10" Margin="2,4,6,4">
                            <Border Background="#15FFFFFF" CornerRadius="5" Width="8" HorizontalAlignment="Center"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Width="10">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource PremiumScrollBarThumb}" Width="8"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium ScrollViewer Style -->
        <Style x:Key="PremiumScrollViewer" TargetType="ScrollViewer">
            <Setter Property="CanContentScroll" Value="False"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0" CanContentScroll="False"
                                                    Content="{TemplateBinding Content}"
                                                    Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                       Orientation="Vertical" Style="{StaticResource PremiumScrollBar}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Template for Pair Tabs -->
        <ControlTemplate x:Key="CloseButtonTemplate" TargetType="Button">
            <Border x:Name="border" Background="#30FFFFFF" CornerRadius="3" Padding="4,2" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#50FFFFFF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar - Demo Mode & Active Pairs Tabs -->
        <Border Grid.Row="0" Background="#10FFFFFF" Padding="15,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Trading Mode Panel (Demo/Real) -->
                <Border x:Name="TradingModePanel" Grid.Column="0" CornerRadius="12" Padding="15,10" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop x:Name="ModePanelColor1" Color="#20F59E0B" Offset="0"/>
                            <GradientStop x:Name="ModePanelColor2" Color="#10F59E0B" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mode Icon & Label -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="ModeIcon" Text="🎮" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="DemoModeBadge" CornerRadius="6" Padding="10,4">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#F59E0B" Offset="0"/>
                                                <GradientStop Color="#D97706" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock x:Name="DemoModeText" Text="DEMO MODE" FontSize="12" FontWeight="Bold" Foreground="#0A0A1A"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="ModeDescription" Text="ใช้เงินเสมือน - ปลอดภัย" FontSize="9" Foreground="#80FFFFFF" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Balance Display - Starting & Current -->
                        <Border Grid.Column="1" Background="#10FFFFFF" CornerRadius="10" Padding="15,8" Margin="15,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Starting Balance -->
                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock x:Name="BalanceLabelStart" Text="💰 เริ่มต้น:" FontSize="9" Foreground="#80FFFFFF"/>
                                    <TextBlock x:Name="StartingBalance" Text="$10,000.00" FontSize="14" FontWeight="SemiBold" Foreground="#A78BFA"
                                               ToolTip="ยอดเงินตอนเริ่มต้น Session"/>
                                </StackPanel>

                                <!-- Arrow / Separator -->
                                <TextBlock Grid.Column="1" Text="→" FontSize="16" Foreground="#40FFFFFF" VerticalAlignment="Center" Margin="0,0,15,0"/>

                                <!-- Current Balance -->
                                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                                    <TextBlock x:Name="BalanceLabel" Text="📊 ปัจจุบัน:" FontSize="9" Foreground="#80FFFFFF"/>
                                    <TextBlock x:Name="DemoWalletBalance" Text="$10,000.00" FontSize="16" FontWeight="Bold" Foreground="White"
                                               ToolTip="ยอดเงินปัจจุบัน"/>
                                </StackPanel>

                                <!-- Profit/Loss Indicator -->
                                <Border Grid.Column="3" x:Name="PnLBadge" CornerRadius="6" Padding="8,4" VerticalAlignment="Center"
                                        Background="#2010B981">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="PnLIcon" Text="📈" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="PnLText" Text="+$0.00" FontSize="11" FontWeight="Bold" Foreground="#10B981"/>
                                        <TextBlock x:Name="PnLPercent" Text=" (0.00%)" FontSize="9" Foreground="#10B981" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Toggle Switch -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="DEMO" FontSize="10" Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Border x:Name="DemoRealToggle" Width="50" Height="26" CornerRadius="13"
                                    Background="#30FFFFFF" Cursor="Hand"
                                    MouseLeftButtonDown="ToggleDemoMode_Click" ToolTip="สลับระหว่าง Demo และ Real Mode">
                                <Ellipse x:Name="DemoRealToggleKnob" Width="20" Height="20" Fill="White"
                                         HorizontalAlignment="Left" Margin="3,0,0,0"
                                         IsHitTestVisible="False">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                            <TextBlock Text="REAL" FontSize="10" Foreground="#60FFFFFF" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Real Mode Warning Banner (Hidden by default) - IsHitTestVisible=False so it doesn't block clicks -->
                <Border x:Name="RealModeWarning" Grid.Column="0" Grid.ColumnSpan="3" Background="#30EF4444" CornerRadius="8"
                        Padding="10,6" Margin="0,5,0,0" Visibility="Collapsed" VerticalAlignment="Bottom"
                        IsHitTestVisible="False">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⚠️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="REAL MODE - ใช้เงินจริง!" FontSize="11" FontWeight="Bold" Foreground="#EF4444" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RealBalanceText" Text="" FontSize="10" Foreground="#F87171" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Active Pairs Tabs (max 10) - with overflow control -->
                <Border Grid.Column="1" Background="#08FFFFFF" CornerRadius="8" Margin="10,0" Padding="5" ClipToBounds="True">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  Style="{StaticResource PremiumScrollViewer}">
                        <StackPanel x:Name="ActivePairsTabs" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Dynamic tabs will be added in code-behind -->

                            <!-- Add New Pair Button -->
                            <Border x:Name="AddPairButton" Background="#15FFFFFF" CornerRadius="8" Padding="10,6" Margin="4,0,0,0"
                                    Cursor="Hand" MouseLeftButtonDown="AddPair_Click" ToolTip="Add trading pair (max 10)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="14" FontWeight="Bold" Foreground="#7C3AED" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PairCount" Text="1/10" FontSize="10" Foreground="#60FFFFFF" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Scan Pairs Button -->
                <Button Grid.Column="2" Padding="15,10" Style="{StaticResource ActionButton}" Click="ScanPairs_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="#5B21B6" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="SCAN PAIRS" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content Area - Responsive Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="280" MaxWidth="350"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="Auto" MinWidth="280" MaxWidth="380"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Exchange Selection & Strategy -->
            <ScrollViewer Style="{StaticResource PremiumScrollViewer}" Grid.Column="0" Margin="0,0,10,0" MaxWidth="350">
                <StackPanel>
                    <!-- Exchange Tabs -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="SELECT EXCHANGE / เลือกกระดาน" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,15"/>

                            <WrapPanel x:Name="ExchangeTabs">
                                <!-- Binance -->
                                <Border x:Name="BinanceTab" Style="{StaticResource SelectedExchangeTab}"
                                        MouseLeftButtonDown="ExchangeTab_Click" Tag="Binance">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ExchangeIcon ExchangeName="Binance" Size="24" Margin="0,0,8,0"/>
                                        <TextBlock Text="Binance" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- KuCoin -->
                                <Border x:Name="KuCoinTab" Style="{StaticResource ExchangeTabStyle}"
                                        MouseLeftButtonDown="ExchangeTab_Click" Tag="KuCoin">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ExchangeIcon ExchangeName="KuCoin" Size="24" Margin="0,0,8,0"/>
                                        <TextBlock Text="KuCoin" FontWeight="SemiBold" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- OKX -->
                                <Border x:Name="OKXTab" Style="{StaticResource ExchangeTabStyle}"
                                        MouseLeftButtonDown="ExchangeTab_Click" Tag="OKX">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ExchangeIcon ExchangeName="OKX" Size="24" Margin="0,0,8,0"/>
                                        <TextBlock Text="OKX" FontWeight="SemiBold" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Bybit -->
                                <Border x:Name="BybitTab" Style="{StaticResource ExchangeTabStyle}"
                                        MouseLeftButtonDown="ExchangeTab_Click" Tag="Bybit">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ExchangeIcon ExchangeName="Bybit" Size="24" Margin="0,0,8,0"/>
                                        <TextBlock Text="Bybit" FontWeight="SemiBold" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Gate.io -->
                                <Border x:Name="GateIOTab" Style="{StaticResource ExchangeTabStyle}"
                                        MouseLeftButtonDown="ExchangeTab_Click" Tag="Gate.io">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ExchangeIcon ExchangeName="Gate.io" Size="24" Margin="0,0,8,0"/>
                                        <TextBlock Text="Gate.io" FontWeight="SemiBold" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Bitkub -->
                                <Border x:Name="BitkubTab" Style="{StaticResource ExchangeTabStyle}"
                                        MouseLeftButtonDown="ExchangeTab_Click" Tag="Bitkub">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ExchangeIcon ExchangeName="Bitkub" Size="24" Margin="0,0,8,0"/>
                                        <TextBlock Text="Bitkub" FontWeight="SemiBold" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <!-- Connection Status -->
                            <Border Background="#10FFFFFF" CornerRadius="8" Padding="10" Margin="0,15,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="ConnectionDot" Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="ConnectionStatus" Text="Connected / เชื่อมต่อแล้ว" FontSize="11" Foreground="#10B981"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Trading Pair Selection -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="TRADING PAIR / คู่เทรด" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="SymbolSearch" Style="{StaticResource DarkTextBox}"
                                         Text="BTC/USDT" FontSize="16" FontWeight="Bold"
                                         TextChanged="SymbolSearch_TextChanged"/>

                                <Button Grid.Column="1" Content="Search" Margin="8,0,0,0"
                                        Style="{StaticResource ActionButton}" Click="SearchSymbol_Click">
                                    <Button.Background>
                                        <SolidColorBrush Color="#7C3AED"/>
                                    </Button.Background>
                                </Button>
                            </Grid>

                            <!-- Quick Pairs -->
                            <TextBlock Text="Quick Select:" FontSize="10" Foreground="#50FFFFFF" Margin="0,12,0,5"/>
                            <WrapPanel>
                                <Button Content="BTC/USDT" Padding="10,5" Margin="0,0,5,5" FontSize="11"
                                        Style="{StaticResource ActionButton}" Click="QuickPair_Click" Tag="BTC/USDT">
                                    <Button.Background><SolidColorBrush Color="#20FFFFFF"/></Button.Background>
                                </Button>
                                <Button Content="ETH/USDT" Padding="10,5" Margin="0,0,5,5" FontSize="11"
                                        Style="{StaticResource ActionButton}" Click="QuickPair_Click" Tag="ETH/USDT">
                                    <Button.Background><SolidColorBrush Color="#20FFFFFF"/></Button.Background>
                                </Button>
                                <Button Content="SOL/USDT" Padding="10,5" Margin="0,0,5,5" FontSize="11"
                                        Style="{StaticResource ActionButton}" Click="QuickPair_Click" Tag="SOL/USDT">
                                    <Button.Background><SolidColorBrush Color="#20FFFFFF"/></Button.Background>
                                </Button>
                                <Button Content="XRP/USDT" Padding="10,5" Margin="0,0,5,5" FontSize="11"
                                        Style="{StaticResource ActionButton}" Click="QuickPair_Click" Tag="XRP/USDT">
                                    <Button.Background><SolidColorBrush Color="#20FFFFFF"/></Button.Background>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- AI Strategy Selection -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="AI STRATEGY / กลยุทธ์ AI" FontSize="11" FontWeight="Bold" Foreground="#60FFFFFF"/>
                                <Border Background="#207C3AED" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                                    <TextBlock Text="SMART" FontSize="9" FontWeight="Bold" Foreground="#7C3AED"/>
                                </Border>
                            </Grid>

                            <!-- Auto Strategy Toggle -->
                            <Border x:Name="AutoStrategyPanel" Background="#1510B981" CornerRadius="10" Padding="12,10" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="🤖" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="AUTO STRATEGY" FontSize="11" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="AutoStrategyDescription" Text="AI จะเลือกกลยุทธ์ตามสภาพตลาด"
                                                   FontSize="9" Foreground="#80FFFFFF" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Toggle Switch -->
                                    <Border Grid.Column="1" x:Name="AutoStrategyToggle" Width="44" Height="24" CornerRadius="12"
                                            Background="#30FFFFFF" Cursor="Hand" Margin="10,0,0,0"
                                            MouseLeftButtonDown="AutoStrategyToggle_Click">
                                        <Ellipse x:Name="AutoStrategyToggleKnob" Width="18" Height="18" Fill="White"
                                                 HorizontalAlignment="Left" Margin="3,0,0,0">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
